# api_hoard/.env 로 복사 후 값만 넣기 (원본은 커밋하지 말 것)
# FRED 무료 키: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA(미) 에너지·정유: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# 한국은행 ECOS: https://ecos.bok.or.kr/ (catalog.json의 bok_ecos_template 참고)

# 일부만 실행: set API_HOARD_ONLY=frankfurter_usd_krw,worldbank_kr_gdp_current_usd
# API_HOARD_ONLY=

# 시계열 스냅샷 복제 저장: API_HOARD_HISTORY=1
# API_HOARD_HISTORY=
